# Local Development Environment Variables
# Copy this file to .env.local and fill in your real values (never commit .env.local to Git)

# ─── Firebase Configuration (Blog CMS — Auth + Firestore only) ────────
# Get these values from: Firebase Console → Project Settings → General → Your Apps → Web App
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Cloudinary Configuration (Image Storage) ───────────────────────────
# Sign up free at cloudinary.com — Dashboard shows your Cloud Name
# Create an UNSIGNED upload preset: Settings → Upload → Add upload preset
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_here

# ─── Development Site Configuration ──────────────────────────────────────────
VITE_SITE_URL=http://localhost:5173
VITE_SITE_NAME=Amogh Van/Bus Services (Dev)

# ─── EmailJS Configuration ────────────────────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
