rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Blogs collection ──────────────────────────────────────────────────
    match /blogs/{blogId} {
      // Public users can read Published blogs only
      allow read: if resource.data.status == "Published";

      // Admin can read ALL blogs (Draft + Published)
      allow read: if request.auth != null;

      // Only authenticated admins can create/update/delete
      allow create, update, delete: if request.auth != null;
    }

    // ── AdminUsers collection ─────────────────────────────────────────────
    match /AdminUsers/{userId} {
      // Admins can only read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── BlogImages collection (optional metadata) ─────────────────────────
    match /BlogImages/{imageId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
